# Consensus API — Environment Variables
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

DB_URL=jdbc:postgresql://localhost:5432/consensus
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_DRIVER=org.postgresql.Driver

DDL_AUTO=update
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
SHOW_SQL=true

JWT_ISSUER=https://your-tenant.logto.app/oidc
JWKS_URI=https://your-tenant.logto.app/oidc/jwks
AUDIENCE=https://api.consensus.your-domain.com
CLIENT_ID=your-logto-client-id

CORS_ORIGINS=https://consensus.your-domain.com

PORT=8080

LOG_LEVEL=DEBUG
HIBERNATE_SQL=DEBUG
